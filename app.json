        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#F3FFE8"
      },
      "package": "com.zuzulogicpark.app",
      "versionCode": 1,
      "edgeToEdgeEnabled": true,
      "permissions": []
    }
  }
}
